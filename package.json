{
    "name": "jandan-vscode",
    "displayName": "JanDan",
    "version": "0.2.1",
    "description": "A VS Code extension for JanDan.",
    "categories": [
        "Other"
    ],
    "keywords": [
        "jandan",
        "jiandan",
        "娱乐",
        "煎蛋"
    ],
    "bugs": "https://github.com/TaipaXu/jandan-vscode/issues",
    "license": "GPL-3.0",
    "author": {
        "name": "Taipa Xu"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/TaipaXu/jandan-vscode"
    },
    "publisher": "TaipaXu",
    "main": "./out/extension.js",
    "scripts": {
        "dev": "vp build --watch --mode development",
        "build": "vp build",
        "type-check": "tsc --noEmit",
        "lint": "vp lint . --fix",
        "format": "vp fmt .",
        "check": "vp check .",
        "package": "vp run build && vp exec vsce package --no-dependencies",
        "prepare": "vp config"
    },
    "devDependencies": {
        "@types/node": "^24.13.2",
        "@types/vscode": "^1.125.0",
        "@voidzero-dev/vite-plus-core": "^0.2.1",
        "@vscode/vsce": "^3.9.2",
        "typescript": "^6.0.3",
        "vite-plus": "^0.2.1"
    },
    "contributes": {
        "commands": [
            {
                "command": "jandan.topRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.newsPrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.newsNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.newsRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.picPrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.picNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.picRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.ooxxPrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.ooxxNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.ooxxRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.nvzhuangPrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.nvzhuangNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.nvzhuangRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.treeholePrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.treeholeNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.treeholeRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.qaPrevious",
                "title": "上一页",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jandan.qaNext",
                "title": "下一页",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jandan.qaRefresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "jandan.oo",
                "title": "oo"
            },
            {
                "command": "jandan.xx",
                "title": "xx"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "jandan.topRefresh",
                    "when": "view == top",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.newsPrevious",
                    "when": "view == news",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.newsNext",
                    "when": "view == news",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.newsRefresh",
                    "when": "view == news",
                    "group": "navigation@2"
                },
                {
                    "command": "jandan.picPrevious",
                    "when": "view == pic",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.picNext",
                    "when": "view == pic",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.picRefresh",
                    "when": "view == pic",
                    "group": "navigation@2"
                },
                {
                    "command": "jandan.ooxxPrevious",
                    "when": "view == ooxx",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.ooxxNext",
                    "when": "view == ooxx",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.ooxxRefresh",
                    "when": "view == ooxx",
                    "group": "navigation@2"
                },
                {
                    "command": "jandan.nvzhuangPrevious",
                    "when": "view == nvzhuang",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.nvzhuangNext",
                    "when": "view == nvzhuang",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.nvzhuangRefresh",
                    "when": "view == nvzhuang",
                    "group": "navigation@2"
                },
                {
                    "command": "jandan.treeholePrevious",
                    "when": "view == treehole",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.treeholeNext",
                    "when": "view == treehole",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.treeholeRefresh",
                    "when": "view == treehole",
                    "group": "navigation@2"
                },
                {
                    "command": "jandan.qaPrevious",
                    "when": "view == qa",
                    "group": "navigation@0"
                },
                {
                    "command": "jandan.qaNext",
                    "when": "view == qa",
                    "group": "navigation@1"
                },
                {
                    "command": "jandan.qaRefresh",
                    "when": "view == qa",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "jandan.oo",
                    "when": "view == top && viewItem == voteable"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == top && viewItem == voteable"
                },
                {
                    "command": "jandan.oo",
                    "when": "view == pic"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == pic"
                },
                {
                    "command": "jandan.oo",
                    "when": "view == ooxx"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == ooxx"
                },
                {
                    "command": "jandan.oo",
                    "when": "view == nvzhuang"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == nvzhuang"
                },
                {
                    "command": "jandan.oo",
                    "when": "view == treehole"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == treehole"
                },
                {
                    "command": "jandan.oo",
                    "when": "view == qa"
                },
                {
                    "command": "jandan.xx",
                    "when": "view == qa"
                }
            ],
            "commandPalette": [
                {
                    "command": "jandan.topRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.newsPrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.newsNext",
                    "when": "never"
                },
                {
                    "command": "jandan.newsRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.picPrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.picNext",
                    "when": "never"
                },
                {
                    "command": "jandan.picRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.ooxxPrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.ooxxNext",
                    "when": "never"
                },
                {
                    "command": "jandan.ooxxRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.nvzhuangPrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.nvzhuangNext",
                    "when": "never"
                },
                {
                    "command": "jandan.nvzhuangRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.treeholePrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.treeholeNext",
                    "when": "never"
                },
                {
                    "command": "jandan.treeholeRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.qaPrevious",
                    "when": "never"
                },
                {
                    "command": "jandan.qaNext",
                    "when": "never"
                },
                {
                    "command": "jandan.qaRefresh",
                    "when": "never"
                },
                {
                    "command": "jandan.oo",
                    "when": "never"
                },
                {
                    "command": "jandan.xx",
                    "when": "never"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "jandan",
                    "title": "JanDan",
                    "icon": "static/images/icon.svg"
                }
            ]
        },
        "views": {
            "jandan": [
                {
                    "id": "top",
                    "name": "热榜"
                },
                {
                    "id": "news",
                    "name": "新鲜事"
                },
                {
                    "id": "pic",
                    "name": "无聊图"
                },
                {
                    "id": "ooxx",
                    "name": "随手拍"
                },
                {
                    "id": "nvzhuang",
                    "name": "女装"
                },
                {
                    "id": "treehole",
                    "name": "树洞"
                },
                {
                    "id": "qa",
                    "name": "问答"
                },
                {
                    "id": "support",
                    "name": "支援煎蛋"
                }
            ]
        }
    },
    "icon": "static/images/icon.png",
    "engines": {
        "node": "24.17.0",
        "vscode": "^1.125.0"
    },
    "packageManager": "pnpm@11.5.2"
}
